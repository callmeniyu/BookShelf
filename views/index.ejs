    <body>
        <div class="landing-page" id="landing-page">
            <img src="/images/pexels-ricky-esquivel-1907785.jpg" alt="book-rack-img" class="book-rack-img" />
            <nav>
                <div class="logo-container poppins">
                    <h3>book <span class="logo-span">shelf</span></h3>
                </div>
                    <ul class="nav-item">
                        <li><a href="">About</a></li>
                        <li>
                            <div class="nav-items-div-black">
                                <ul class="nav-items">
                                    <li><a href="">Contact</a></li>
                                    <li>
                                        <a href=""
                                            >Sort by<svg
                                                class = "sort icon"
                                                xmlns="http://www.w3.org/2000/svg"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke-width="1.5"
                                                stroke="currentColor"
                                                class="w-6 h-6 "
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="m19.5 8.25-7.5 7.5-7.5-7.5"
                                                /></svg
                                        ></a>
                                    </li>
                                    <li class="abc">
